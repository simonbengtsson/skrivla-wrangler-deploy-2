{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "skrivla-wrangler-deploy-2",
  "compatibility_date": "2026-04-20",
  "main": "src/server/worker.ts",
  "vars": {
    "LUVABASE": "no", // Will be overriden to "yes" on luvabase, stay as "no" on cloudflare
  },
  "assets": {
    "directory": "public",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*",
      "/luvabase/*"
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "MainDO",
      ],
    },
    {
      "tag": "v2",
      "new_sqlite_classes": [
        "WorkspaceDO",
        "PageDO",
      ],
      "deleted_classes": [
        "MainDO",
      ],
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "WORKSPACE_DO",
        "class_name": "WorkspaceDO",
      },
      {
        "name": "PAGE_DO",
        "class_name": "PageDO",
      },
    ],
  },
}